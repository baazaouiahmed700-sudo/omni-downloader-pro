# ─────────────────────────────────────────────────────────────────────────────
# Omni-Downloader Pro — Environment Variables
# Copy this file to .env and fill in your values for LOCAL development.
# On Render, set these in the dashboard (Environment tab).
# NEVER commit your real .env file to Git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Render service URL (set AFTER first deploy)
# Example: https://omni-downloader-pro.onrender.com
WEBHOOK_URL=https://your-app-name.onrender.com

# ── Optional — Gemini AI Features ────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
# Leave empty to disable AI analysis features
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional — Local Dev Override ────────────────────────────────────────────
PORT=8000
